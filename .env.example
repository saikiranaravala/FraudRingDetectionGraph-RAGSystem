# Neo4j Aura connection — copy this file to .env and fill in your values
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Directory that contains all node/edge CSV files
DATA_DIR=./data

# Rows per UNWIND batch sent to Neo4j (tune for your instance size)
BATCH_SIZE=200

# Skip TLS cert verification (set to true on Windows — Aura intermediate CA
# is often not trusted by the Python ssl/certifi bundle)
NEO4J_TRUST_ALL_CERTS=true

# OpenRouter (Phase 3 LLM)
# Options:
#   anthropic/claude-sonnet-4-5 — best quality, $3-15/M tokens (reliable, working now)
#   google/gemma-4-31b-it:free — free but needs setup in OpenRouter settings
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Google API key (required for Gemma; get from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Vector store (switched to Pinecone for Render free plan)
VECTOR_STORE_BACKEND=pinecone
PINECONE_API_KEY=pcsk_....
PINECONE_INDEX=fraud-rings

# Embedding model (fastembed ONNX-based, no PyTorch required — ~100 MB RAM)
# BAAI/bge-small-en-v1.5: 384-dim, fast, fits Render free plan (512 MB)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LangSmith Configuration (Optional - for monitoring)
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT="FraudRingDetectionGraph-RAG"
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
